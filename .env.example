# NovaMail Environment Configuration
# Copy this file to .env and fill in your values

# ─── Required: Database ────────────────────────────────────────────
DATABASE_URL=file:./data/novamail.db

# ─── Optional: Gemini AI ──────────────────────────────────────────
# Leave empty to use heuristic fallbacks
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-3.1-flash-lite

# ─── Required: Session ─────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-strong-random-secret

# ─── Setup Instructions ────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Set SESSION_SECRET to a strong random string
# 3. Run: npm install
# 4. Run: npm run db:push
# 5. Run: npm run dev
# 6. Open http://localhost:3000 and log in with your email + app password
#
# For Gmail:
#   - Enable 2FA and create an App Password at myaccount.google.com/security
#   - Use that App Password (not your regular password)
#
# For Outlook/Microsoft 365:
#   - Create an App Password in your account security settings
#
# For Gemini AI features:
#   - Get an API key at https://aistudio.google.com/apikey
#   - Add it to GEMINI_API_KEY
